# Hidden-artifact allowlist: deny dotfiles and dotfolders everywhere in the
# repo unless they are intentionally shared and explicitly included below.
.*
!/.gitignore
!/.gitattributes
!/.dockerignore
!/.editorconfig
!.*.example
!/src/.obsidian/
!/src/.obsidian/**

# Build & runtime junk
node_modules/
dist/
*.log
*.swp
